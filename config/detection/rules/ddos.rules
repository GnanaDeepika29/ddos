# Placeholder local rule set for development.
# The current signature detector simulates matching in Python, but we keep
# a real rules directory so configuration, reload logic, and container mounts
# remain aligned with production expectations.

alert tcp any any -> any any (msg:"Possible SYN flood"; flags:S; sid:1000001; rev:1;)
alert icmp any any -> any any (msg:"Possible ICMP flood"; sid:1000002; rev:1;)
alert udp any any -> any 53 (msg:"Possible DNS amplification"; sid:1000003; rev:1;)
