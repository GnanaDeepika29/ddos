# DDoS Defense Platform Environment Configuration
# Copy this file to .env and modify as needed

# ============================================
# Core Settings
# ============================================
ENVIRONMENT=development  # development, staging, production
LOG_LEVEL=INFO           # DEBUG, INFO, WARNING, ERROR
SECRET_KEY=your-secret-key-here-change-in-production

# ============================================
# Kafka Configuration
# ============================================
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_TELEMETRY=ddos.telemetry.raw
KAFKA_TOPIC_FLOWS=ddos.telemetry.flows
KAFKA_TOPIC_ALERTS=ddos.alerts
KAFKA_TOPIC_MITIGATION_EVENTS=ddos.mitigation.events
KAFKA_CONSUMER_GROUP=ddos-defense-platform
KAFKA_SECURITY_PROTOCOL=PLAINTEXT  # PLAINTEXT, SSL, SASL_SSL
KAFKA_SSL_CA_LOCATION=
KAFKA_SSL_CERTIFICATE_LOCATION=
KAFKA_SSL_KEY_LOCATION=

# ============================================
# Redis (State & Caching)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_SSL=false

# ============================================
# TimescaleDB (Metrics & Historical Data)
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ddos_platform
DB_USER=ddos_user
DB_PASSWORD=change_me
DB_SSL_MODE=disable  # disable, require, verify-ca, verify-full

# ============================================
# API Server
# ============================================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=false  # set true for development
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080"]

# ============================================
# Detection Engine
# ============================================
# Detection thresholds
VOLUMETRIC_THRESHOLD_MBPS=1000.0
VOLUMETRIC_THRESHOLD_PPS=500000
SYN_FLOOD_THRESHOLD=1000  # SYN packets per second per IP
ANOMALY_WINDOW_SECONDS=60
ANOMALY_DEVIATION_FACTOR=3.0

# ML model paths
ML_MODEL_PATH=models/ensemble_model.joblib
ML_FEATURE_EXTRACTOR_PATH=models/feature_extractor.joblib
ML_CONFIDENCE_THRESHOLD=0.85

# ============================================
# Mitigation Actions
# ============================================
MITIGATION_AUTO_RESPONSE=true
MITIGATION_DRY_RUN=false  # if true, only log actions without applying
RATE_LIMIT_DEFAULT_MBPS=100
RATE_LIMIT_DEFAULT_PPS=5000

# BGP Scrubber configuration
BGP_ASN=65000
BGP_ROUTER_IP=192.168.1.1
BGP_SCRUBBER_NEXT_HOP=10.0.0.1
BGP_COMMUNITY=65000:666

# Cloud Provider (choose one)
CLOUD_PROVIDER=aws  # aws, azure, gcp, none

# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_VPC_ID=vpc-xxxxxxxx
AWS_SECURITY_GROUP_ID=sg-xxxxxxxx

# Azure
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_RESOURCE_GROUP=
AZURE_NETWORK_SECURITY_GROUP=

# GCP
GCP_PROJECT_ID=
GCP_CREDENTIALS_PATH=credentials.json
GCP_NETWORK_NAME=default
GCP_FIREWALL_RULE_PREFIX=ddos-mitigation

# ============================================
# SDN Controller (optional)
# ============================================
SDN_CONTROLLER_TYPE=none  # none, onos, opendaylight, ryu
SDN_CONTROLLER_URL=http://localhost:8181
SDN_CONTROLLER_USERNAME=admin
SDN_CONTROLLER_PASSWORD=admin

# ============================================
# Observability
# ============================================
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
OPENTELEMETRY_ENABLED=false
OTLP_ENDPOINT=http://localhost:4317

# ============================================
# Performance Tuning
# ============================================
INGESTION_BATCH_SIZE=1000
INGESTION_BUFFER_TIMEOUT_SECONDS=1
DETECTION_PARALLEL_WORKERS=4
MITIGATION_ACTION_TIMEOUT_SECONDS=30